# ==============================================================================
# Fracture Recovery Companion - Environment Variables (Story 1.1 baseline)
# ==============================================================================
# Copy this file to .env.local for local development.
# Production deployment should configure these on the hosting platform (Vercel).
#
# Story 2.1 wires identity recovery with NextAuth.js Magic Link.
# Additional keys (STRIPE_*, GEMINI, GROQ, UPSTASH_*) are introduced by later
# stories when those features land.
# ==============================================================================

# --- Core ---
# Canonical public URL of the deployment (used for SEO metadata base and canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (NextAuth.js) ---
# NEXTAUTH_URL must match the deployed origin in production
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32   (must be at least 32 chars)
NEXTAUTH_SECRET=replace-with-a-32-char-minimum-random-string-value

# Supabase Postgres connection used by Prisma and NextAuth verification tokens
DATABASE_URL=postgresql://user:password@localhost:5432/fracture_recovery

# Magic Link email transport. Use a local SMTP catcher in dev or a real SMTP
# provider in production.
EMAIL_SERVER=smtp://user:password@localhost:1025
EMAIL_FROM="Fracture Recovery Companion <hello@example.com>"

# --- Observability (Sentry) ---
# Leave empty in local dev; Story 1.1 gracefully no-ops when Sentry DSN is absent.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Optional - required only when uploading source maps during a production build
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
