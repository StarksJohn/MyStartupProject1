# ==============================================================================
# Fracture Recovery Companion - Environment Variables
# ==============================================================================
# Copy this file to .env.local for local development.
# Production deployment should configure these on the hosting platform (Vercel).
#
# Local deterministic QA can run without real Stripe, Sentry, analytics, or AI
# provider credentials. Production launch readiness expects the production
# critical variables below to be configured in the hosting platform.
# ==============================================================================

# --- Core ---
# Canonical public URL of the deployment (used for SEO metadata base and canonical links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Auth (NextAuth.js) ---
# NEXTAUTH_URL must match the deployed origin in production
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32   (must be at least 32 chars)
NEXTAUTH_SECRET=replace-with-a-32-char-minimum-random-string-value

# Supabase Postgres connection used by Prisma and NextAuth verification tokens
DATABASE_URL=postgresql://user:password@localhost:5432/fracture_recovery
# Direct Postgres connection used by Prisma schema sync and generation
DIRECT_URL=postgresql://user:password@localhost:5432/fracture_recovery

# Magic Link email transport. Use a local SMTP catcher in dev or a real SMTP
# provider in production.
EMAIL_SERVER=smtp://user:password@localhost:1025
EMAIL_FROM="Fracture Recovery Companion <hello@example.com>"

# --- Observability (Sentry) ---
# Leave empty in local dev and CI; monitoring capture gracefully no-ops when
# Sentry DSN is absent. Production launch readiness expects both server and
# client DSNs so caught API failures and render boundaries are visible.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Recommended for production source-map uploads. Local dev and CI do not require
# these unless you intentionally verify a production build with source maps.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Product Analytics ---
# Optional. Leave empty for local dev and CI no-op behavior.
# Supported values: plausible, umami
NEXT_PUBLIC_ANALYTICS_PROVIDER=

# --- Billing (Stripe Checkout) ---
# Required in production. Local dev and Playwright use a dev-mock checkout URL
# when this is absent, so Story 2.4 can be tested without live Stripe keys.
STRIPE_SECRET_KEY=
# Required in production for verifying Stripe webhook signatures.
STRIPE_WEBHOOK_SECRET=

# --- AI Chat Providers ---
# Required for production launch readiness. Local E2E uses deterministic test
# provider paths and must not call live Gemini or Groq services by default.
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Chat Quota Store (optional) ---
# Optional. When absent, quota checks fall back to the database-backed path.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
