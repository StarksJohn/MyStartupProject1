// Prisma schema for Fracture Recovery Companion.
//
// Story 2.1 baseline: NextAuth-compatible auth tables only.
// Business models (RecoveryProfile, Purchase, Program, ProgramDay, ChatMessage,
// KnowledgeChunk, etc.) are introduced by later stories per the architecture doc.
//
// See: 技术架构详细设计.md §4 数据模型设计
//      epics.md Epic 3 - Recovery Program Foundation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase Postgres for both dev and prod - see ADR-004 in 技术架构详细设计.md
  // Local dev can also point at a Supabase branch DB.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  recoveryProfile RecoveryProfile?

  @@map("users")
}

model RecoveryProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  bodyPart             String
  subType              String
  castRemovedAt        DateTime
  hasHardware          String
  referredToPt         String
  painLevel            Int
  dominantHandAffected Boolean
  jobType              String
  notes                String?
  riskFlagsJson        Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bodyPart])
  @@index([castRemovedAt])
  @@map("recovery_profiles")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
