// Prisma schema for Fracture Recovery Companion.
//
// Story 3.1 baseline: NextAuth auth tables plus frozen domain models for
// recovery profiles, purchases, programs, chat history, and knowledge chunks.
// pgvector fields use Prisma Unsupported types and must be accessed via raw SQL.
//
// See: 技术架构详细设计.md §4 数据模型设计
//      epics.md Epic 3 - Recovery Program Foundation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Supabase Postgres for both dev and prod - see ADR-004 in 技术架构详细设计.md
  // Local dev can also point at a Supabase branch DB.
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PurchaseStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum ProgramStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

enum ChatConversationStatus {
  ACTIVE
  ARCHIVED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum KnowledgeSourceType {
  AAOS
  NHS
  GUZHE
  FAQ
  BLOG
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  recoveryProfile RecoveryProfile?
  purchases Purchase[]
  programs Program[]
  chatConversations ChatConversation[]

  @@map("users")
}

model RecoveryProfile {
  id                   String   @id @default(cuid())
  userId               String   @unique
  bodyPart             String
  subType              String
  castRemovedAt        DateTime
  hasHardware          String
  referredToPt         String
  painLevel            Int
  dominantHandAffected Boolean
  jobType              String
  notes                String?
  riskFlagsJson        Json?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  programs Program[]

  @@unique([id, userId])
  @@index([bodyPart])
  @@index([castRemovedAt])
  @@map("recovery_profiles")
}

model Purchase {
  id                      String         @id @default(cuid())
  userId                  String
  stripeCheckoutSessionId String         @unique
  stripePaymentIntentId   String?        @unique
  stripeCustomerId        String?
  amount                  Int
  currency                String
  status                  PurchaseStatus @default(PENDING)
  paidAt                  DateTime?
  refundedAt              DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program?

  @@unique([id, userId])
  @@index([userId])
  @@index([status])
  @@map("purchases")
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  processedAt   DateTime?
  payloadJson   Json?
  createdAt     DateTime @default(now())

  @@index([type])
  @@map("stripe_webhook_events")
}

model Program {
  id                   String        @id @default(cuid())
  userId               String
  recoveryProfileId    String
  purchaseId           String        @unique
  templateVersion      String
  startDate            DateTime
  endDate              DateTime
  currentDay           Int           @default(1)
  status               ProgramStatus @default(ACTIVE)
  generatedSummaryJson Json?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recoveryProfile RecoveryProfile @relation(fields: [recoveryProfileId, userId], references: [id, userId], onDelete: Cascade)
  purchase Purchase @relation(fields: [purchaseId, userId], references: [id, userId], onDelete: Cascade)
  days ProgramDay[]
  chatConversations ChatConversation[]

  @@unique([id, userId])
  @@unique([purchaseId, userId])
  @@index([userId])
  @@index([status])
  @@index([currentDay])
  @@map("programs")
}

model ProgramDay {
  id                String    @id @default(cuid())
  programId         String
  dayIndex          Int
  stage             String
  contentJson       Json
  estimatedMinutes  Int
  completedAt       DateTime?
  completionPercent Int       @default(0)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, dayIndex])
  @@index([programId])
  @@index([stage])
  @@map("program_days")
}

model ChatConversation {
  id        String                 @id @default(cuid())
  userId    String
  programId String
  status    ChatConversationStatus @default(ACTIVE)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId, userId], references: [id, userId], onDelete: Cascade)
  messages ChatMessage[]

  @@index([userId])
  @@index([programId])
  @@map("chat_conversations")
}

model ChatMessage {
  id             String          @id @default(cuid())
  conversationId String
  role           ChatMessageRole
  content        String
  citationsJson  Json?
  provider       String?
  model          String?
  escalated      Boolean         @default(false)
  tokenUsageJson Json?
  createdAt      DateTime        @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@index([escalated])
  @@map("chat_messages")
}

model KnowledgeDocument {
  id           String              @id @default(cuid())
  sourceType   KnowledgeSourceType
  title        String
  slug         String
  version      String
  metadataJson Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  chunks KnowledgeChunk[]

  @@unique([sourceType, slug, version])
  @@index([sourceType])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id           String  @id @default(cuid())
  documentId   String
  chunkIndex   Int
  content      String
  // Requires Supabase/Postgres pgvector: CREATE EXTENSION IF NOT EXISTS vector;
  // Prisma Client does not natively read/write vector fields; future stories must use raw SQL.
  embedding    Unsupported("vector(1536)")?
  keywords     String[]
  metadataJson Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("knowledge_chunks")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
